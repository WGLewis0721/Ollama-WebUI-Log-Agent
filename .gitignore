# Sensitive environment files — never commit real credentials
**/.env.rag
**/.env.production
**/.env

# Backup files generated by deploy scripts
**/*.bak
**/*.bak.*
**/docker-compose-rag.yml.backup*
**/docker-compose-rag.yml.bak.*

# Runtime output / log files
**/deploy_v3_output.txt
**/phase*_output.txt

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
env/
venv/
.venv/
*.egg-info/
dist/
build/

# Docker
.docker/

# Log files (keep .gitkeep sentinels)
logs/*.log
output/*
!output/.gitkeep
!logs/.gitkeep

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS artifacts
.DS_Store
Thumbs.db

# Node (if any frontend tooling is added)
node_modules/

# Terraform state (if IaC is added)
*.tfstate
*.tfstate.*
.terraform/
