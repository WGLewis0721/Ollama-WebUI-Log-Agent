# Ollama Configuration
OLLAMA_BASE_URL=http://ollama:11434
MODEL_NAME=llama3.2:3b

# Available models (uncomment to use):
# MODEL_NAME=llama3.2:3b      # Fast, 4GB RAM required
# MODEL_NAME=llama3.1:8b      # Better accuracy, 8GB RAM required
# MODEL_NAME=mistral:7b       # Alternative model
# MODEL_NAME=llama3:70b       # Best accuracy, 48GB+ RAM required

# Analysis Configuration
ANALYSIS_TYPE=general
# Options: general, security, performance, errors

# Watch Mode (continuous monitoring)
WATCH_MODE=false
# Set to true for production monitoring

# Logging
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR

# Paths (usually don't need to change these)
LOG_DIR=/app/logs
OUTPUT_DIR=/app/output
