networks:
  log-analyst-network:
    driver: bridge
services:
  dashboard:
    build:
      context: ./agent
      dockerfile: Dockerfile
    command: python dashboard.py
    container_name: log-analyst-dashboard
    depends_on:
    - log-analyst-rag
    environment:
    - OUTPUT_DIR=/app/output
    - DASHBOARD_PORT=5000
    networks:
    - log-analyst-network
    ports:
    - 5000:5000
    restart: unless-stopped
    volumes:
    - ./output:/app/output:ro
 
  open-webui:
    build:
      context: .
      dockerfile: Dockerfile.open-webui
    container_name: open-webui
    ports:
      - "8080:8080"
    environment:
      - OLLAMA_BASE_URL=http://ollama:11434
      - WEBUI_AUTH=true
      - WEBUI_NAME=CNAP AI Assistant
      - AWS_REGION=us-gov-west-1
      - OPENSEARCH_ENDPOINT=vpc-dev-c-dev-cnap-il6-opensear-gsubaunibfw3i6w2gnjfv4g6w4.us-gov-west-1.es.amazonaws.com
    volumes:
      - open-webui-data:/app/backend/data
    networks:
      - log-analyst-network
    restart: unless-stopped
    depends_on:
      ollama:
        condition: service_healthy
      
  
  indexer:
    build:
      context: ./agent
      dockerfile: Dockerfile
    command: python document_indexer.py index_all
    container_name: document-indexer
    depends_on:
      ollama:
        condition: service_healthy
    env_file:
    - .env.rag
    networks:
    - log-analyst-network
    profiles:
    - tools
    volumes:
    - ~/.aws:/root/.aws:ro
  
  log-analyst-rag:
    build:
      context: ./agent
      dockerfile: Dockerfile
    command: python -u main_rag.py
    container_name: log-analyst-rag
    depends_on:
      ollama:
        condition: service_healthy
    env_file:
    - .env.rag
    networks:
    - log-analyst-network
    restart: unless-stopped
    volumes:
    - ./output:/app/output
    - ./config:/app/config
    - ~/.aws:/root/.aws:ro
  
  ollama:
    container_name: ollama
    deploy:
      resources:
        reservations:
          devices:
          - capabilities:
            - gpu
            count: all
            driver: nvidia
    environment:
    - OLLAMA_HOST=0.0.0.0
    - NVIDIA_VISIBLE_DEVICES=all
    - NVIDIA_DRIVER_CAPABILITIES=compute,utility
    healthcheck:
      interval: 30s
      retries: 3
      test:
      - CMD
      - ollama
      - list
      timeout: 10s
    image: ollama/ollama:0.15.5
    networks:
    - log-analyst-network
    ports:
    - 11434:11434
    restart: unless-stopped
    volumes:
    - ollama_data:/root/.ollama

volumes:
  ollama_data: null
  open-webui-data: null
