# ================================================
# Log Analyst Agent - OpenSearch Configuration
# ================================================

# OpenSearch Endpoint (REQUIRED)
# Get this from your AWS OpenSearch dashboard
# Example: search-my-domain-abc123.us-east-1.es.amazonaws.com
OPENSEARCH_ENDPOINT=your-opensearch-endpoint.region.es.amazonaws.com

# AWS Region
AWS_REGION=us-east-1

# Index Pattern
# Matches your Fluent Bit output index pattern
# Examples: logs-*, application-logs-*, kubernetes-*
OPENSEARCH_INDEX=logs-*

# Time Range (minutes)
# How far back to fetch logs for analysis
TIME_RANGE_MINUTES=60

# Application Filter (optional)
# Filter logs by specific application/service name
# Leave empty to analyze all applications
APPLICATION_NAME=

# Errors Only (optional)
# Set to true to only analyze ERROR/CRITICAL logs
ERRORS_ONLY=false

# ================================================
# Agent Configuration
# ================================================

# Model Selection
# Options: llama3.2:3b, llama3.1:8b, llama3:70b
MODEL_NAME=llama3.1:8b

# Analysis Type
# Options: general, security, performance, errors
ANALYSIS_TYPE=general

# Watch Mode (continuous monitoring)
WATCH_MODE=true
WATCH_INTERVAL_MINUTES=5

# Ollama Configuration
OLLAMA_BASE_URL=http://ollama:11434

# ================================================
# Dashboard Configuration
# ================================================

DASHBOARD_PORT=5000

# ================================================
# AWS Authentication
# ================================================
# Option 1: IAM Role (recommended for EC2)
#   - Attach IAM role to EC2 instance with OpenSearch access
#   - No credentials needed in this file

# Option 2: AWS Credentials (for local development)
#   - Uncomment and fill these in for local testing
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_SESSION_TOKEN=optional-session-token

# ================================================
# Example Configurations
# ================================================

# Example 1: Analyze all logs from last hour
# OPENSEARCH_INDEX=logs-*
# TIME_RANGE_MINUTES=60
# ANALYSIS_TYPE=general
# WATCH_MODE=true

# Example 2: Security audit of production API
# OPENSEARCH_INDEX=api-logs-prod-*
# APPLICATION_NAME=api-gateway
# ANALYSIS_TYPE=security
# TIME_RANGE_MINUTES=1440  # Last 24 hours

# Example 3: Performance monitoring
# OPENSEARCH_INDEX=app-logs-*
# ANALYSIS_TYPE=performance
# TIME_RANGE_MINUTES=30
# WATCH_MODE=true
# WATCH_INTERVAL_MINUTES=15

# Example 4: Error tracking
# OPENSEARCH_INDEX=logs-*
# ERRORS_ONLY=true
# ANALYSIS_TYPE=errors
# WATCH_MODE=true
